# Copy this file to .env and fill in your real values.
# NEVER commit .env with real credentials to version control.

RAPIDAPI_KEY=YOUR_RAPIDAPI_KEY_HERE
RAPIDAPI_HOST=sarkari-result.p.rapidapi.com
RAPIDAPI_URL_RESULTS=https://sarkari-result.p.rapidapi.com/results/
RAPIDAPI_URL_JOBS=https://sarkari-result.p.rapidapi.com/jobs/

# Optional: Firebase service account JSON as a single-line string.
# If not set, the script reads ./serviceAccountKey.json (also gitignored).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
